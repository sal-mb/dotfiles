{
    "layer": "top", // Waybar at top layer
    "position": "top", // Waybar at the bottom of your screen
    "height": 24, // Waybar height
    "margin-left": 10,
    "margin-bottom": 0,
    "margin-right": 10,

    // "width": 1366, // Waybar width
    // Choose the order of the modules
    "modules-left": ["hyprland/workspaces", "hyprland/mode"],
    "modules-center": ["sp","hyprland/window","sp"],
    "modules-right": ["pulseaudio", "network", "tray", "clock", "custom/notification", "custom/power"],

    
    // MODULES 

    "custom/sp": {
      "format": "   ",
      "tooltip": false
    },
    "hyprland/workspaces": {
        "all-outputs": true,
        "disable-scroll": true,
        "show-special": true,
        "on-click": "activate",
        "format": "{icon}",
